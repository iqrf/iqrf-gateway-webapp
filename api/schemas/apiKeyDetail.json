{
	"$schema": "http://json-schema.org/draft-07/schema",
	"$id": "https://apidocs.iqrf.org/openapi/iqrf-gateway-webapp/schemas/apiKeyDetail.json",
	"type": "object",
	"title": "API key detail",
	"additionalProperties": false,
	"required": [
		"id",
		"description",
		"expiration"
	],
	"properties": {
		"id": {
			"$id": "#/properties/id",
			"type": "integer",
			"title": "API key ID",
			"example": 1
		},
		"description": {
			"$id": "#/properties/description",
			"type": "string",
			"title": "API key description",
			"example": "My awesome app"
		},
		"expiration": {
			"$id": "#/properties/expiration",
			"oneOf": [
				{
					"type": "string",
					"format": "date-time"
				},
				{
					"type": "null"
				}
			],
			"title": "API key expiration",
			"example": null
		},
		"revokedBy": {
			"$id": "#/properties/revokedBy",
			"title": "Revoked by user",
			"oneOf": [
				{
					"$ref": "https://apidocs.iqrf.org/openapi/iqrf-gateway-webapp/schemas/userDetail.json"
				},
				{
					"type": "null"
				}
			]
		},
		"revokedAt": {
			"$id": "#/properties/revokedAt",
			"oneOf": [
				{
					"type": "string",
					"format": "date-time"
				},
				{
					"type": "null"
				}
			],
			"title": "API key expiration",
			"example": null
		},
		"state": {
			"$id": "#/properties/state",
			"title": "API key state",
			"type": "string",
			"enum": [
				"active",
				"revoked"
			]
		},
		"scopes": {
			"$ref": "https://apidocs.iqrf.org/openapi/iqrf-gateway-webapp/schemas/accessScopes.json"
		},
		"legacy": {
			"$id": "#/properties/legacy",
			"title": "Legacy flag",
			"type": "boolean",
			"example": true
		}
	}
}
