{
	"compilerOptions": {
		"allowJs": false,
		"baseUrl": "./",
		"composite": true,
		"declaration": true,
		"declarationDir": "./dist",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"incremental": true,
		"lib": [
			"ESNext",
			"DOM"
		],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"outDir": "./dist",
		"paths": {
			"@iqrf/iqrf-gateway-daemon-utils": ["../daemon-utils/src"],
			"@iqrf/iqrf-gateway-daemon-utils/*": ["../daemon-utils/src/*"]
		},
		"resolveJsonModule": true,
		"rootDir": "./",
		"sourceMap": true,
		"strict": true,
		"strictNullChecks": true,
		"target": "ES2020"
	},
	"include": [
		"src/**/*",
		"tests/**/*",
		"package.json",
		"vitest.config.ts"
	],
	"exclude": [
		"dist",
		"docs",
		"node_modules"
	]
}
